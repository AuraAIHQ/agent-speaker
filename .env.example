# Agent Speaker 测试环境配置
# 复制为 .env 后填入真实密钥

# ============================================
# 测试用户 A: Alice (发起人)
# ============================================
ALICE_NSEC=nsec1aliceTESTKEY000000000000000000000000000000000000000000000
ALICE_NPUB=npub1aliceTESTPUB000000000000000000000000000000000000000000000
ALICE_NAME=Alice
ALICE_ROLE=发起人

# ============================================
# 测试用户 B: Bob (接收人)
# ============================================
BOB_NSEC=nsec1bobTESTKEY0000000000000000000000000000000000000000000000000
BOB_NPUB=npub1bobTESTPUB0000000000000000000000000000000000000000000000000
BOB_NAME=Bob
BOB_ROLE=接收人

# ============================================
# 测试用户 C: Charlie (观察者)
# ============================================
CHARLIE_NSEC=nsec1charlieTESTKEY000000000000000000000000000000000000000000
CHARLIE_NPUB=npub1charlieTESTPUB000000000000000000000000000000000000000000
CHARLIE_NAME=Charlie
CHARLIE_ROLE=观察者

# ============================================
# Relay 配置
# ============================================
# 国内用户推荐使用以下 Relay（无需翻墙）
# 更多 Relay 列表: https://nostr.watch/
RELAY_PUBLIC=wss://relay.nostr.band
RELAY_BACKUP=wss://nos.lol
RELAY_CN=wss://relay.nostr.cn
RELAY_HK=wss://relay.nostr.hk

# 本地 Mini Relay (Charlie 启动)
RELAY_LOCAL=ws://localhost:7777

# ============================================
# 测试配置
# ============================================
# 测试超时时间(秒)
TEST_TIMEOUT=30

# 是否启用压缩
TEST_COMPRESS=true

# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info
